# App
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sastlink
DB_PASSWORD=change_me
DB_NAME=sastlink
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0
REDIS_KEY_PREFIX=sastlink

# JWT / OAuth tokens
# JWT_SECRET_KEY is the active RSA private key. JWT_SECRET_KEY_PREV may contain
# the previous RSA private or public key and is used only to verify tokens during rotation.
JWT_SECRET_KEY="-----BEGIN RSA PRIVATE KEY-----\nchange_me\n-----END RSA PRIVATE KEY-----"
JWT_SECRET_KEY_PREV=
JWT_ACTIVE_KID=link-v2-active
JWT_PREVIOUS_KID=
JWT_ISSUER=https://link.sast.fun/v2
JWT_AUDIENCE=sast-link-v2
JWT_ACCESS_TOKEN_EXPIRY=1h
JWT_REFRESH_TOKEN_EXPIRY=720h
REFRESH_TOKEN_HMAC_SECRET=replace_with_at_least_32_random_bytes

# SMTP
SMTP_HOST=smtp.feishu.cn
SMTP_PORT=465
SMTP_USERNAME=your-bot@feishu.cn
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@sast.fun
SMTP_USE_TLS=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# OAuth Providers (enable as needed)
OAUTH_FEISHU_ENABLED=false
OAUTH_FEISHU_CLIENT_ID=
OAUTH_FEISHU_CLIENT_SECRET=
OAUTH_FEISHU_REDIRECT_URI=http://localhost:3000/oauth/callback/feishu
OAUTH_GITHUB_ENABLED=false
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_GITHUB_REDIRECT_URI=http://localhost:3000/oauth/callback/github

# Object Storage (S3/COS/MinIO)
STORAGE_PROVIDER=cos
STORAGE_ENDPOINT=
STORAGE_REGION=
STORAGE_BUCKET=
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BASE_URL=

# Rate Limiting
RATE_LIMIT_GLOBAL_RPS=100
RATE_LIMIT_LOGIN_RPM=5
RATE_LIMIT_SEND_EMAIL_RPM=3
RATE_LIMIT_CAPTCHA_RPM=5
RATE_LIMIT_REGISTER_RPH=3

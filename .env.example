# App
APP_ENV=development
APP_PORT=8080
LOG_LEVEL=debug

# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=sastlink
DB_PASSWORD=change_me
DB_NAME=sastlink
DB_SSLMODE=disable

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change_me
REDIS_DB=0

# JWT
JWT_SECRET_KEY=change_me_to_64_char_random_string
JWT_EXPIRY=168h

# SMTP
SMTP_HOST=smtp.feishu.cn
SMTP_PORT=465
SMTP_USERNAME=your-bot@feishu.cn
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@sast.fun
SMTP_USE_TLS=true

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Initial super admin (optional)
INITIAL_SUPER_ADMIN_UID=
